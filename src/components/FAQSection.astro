---
interface FAQ {
  question: string;
  answer: string;
}

interface Props {
  faqs: FAQ[];
}

const { faqs } = Astro.props;
---

<section id="faq" class="section faq" aria-labelledby="faq-title">
  <div>
    <p class="eyebrow">FAQ</p>
    <h2 id="faq-title">Questions your CFO is already sweating.</h2>
  </div>
  <div class="faq-list">
    {faqs.map((faq) => (
      <article>
        <h3>{faq.question}</h3>
        <p>{faq.answer}</p>
      </article>
    ))}
  </div>
</section>
