  },
  {
    icon: '🏆',
    title: 'Victory & tar aroma',
    copy: 'Walk back into the boardroom smelling like cedar, decisive leadership, and one suspiciously premium campfire.',
  },
  {
    icon: '📈',
    title: 'Heat-level analytics',
    copy: 'Track sweat velocity, action-item evaporation, and how often Sales says “disruptive” inside a 190° sauna.',
  },
];

const plans = [
  {
    name: 'Warm Intro',
    price: '$899',
    period: '/ ambush',
    featured: false,
    copy: 'For startups that say “family” but mean “bring your own towel.”',
    items: ['One sauna truck visit', 'Two birch morale boosts', 'Slack status: In deep focus', 'Tar-scented badge sticker'],
  },
  {
    name: 'Synergy Steam',
    price: '$4,200',
    period: '/ month',
    featured: true,
    copy: 'The executive favorite. Enough heat to melt silos and weak OKRs.',
    items: ['Weekly monster truck deployments', 'Productivity heat levels 1–7', 'Quarterly sweat retrospective', 'Priority parking-lot intimidation'],
  },
  {
    name: 'Boardroom Inferno',
    price: 'Custom',
    period: '',
    featured: false,
    copy: 'For enterprises ready to boil bureaucracy until it becomes soup.',
    items: ['Dedicated Chief Sweat Officer', 'Unlimited birch ceremonies', 'SEC-compliant towel storage', 'White-glove all-hands evacuation'],
  },
];

const testimonials = [
  {
    quote: 'I stepped out during a budget meeting and came back with pores so open I approved the roadmap by smell alone.',
    name: 'Dick Swett',
    title: 'CEO, MoistMetrics Global',
  },
  {
    quote: 'Our velocity doubled after Sauna-as-a-Service. Mostly because everyone sprinted back inside when the truck did a wheelie.',
    name: 'Ben Dover',
    title: 'Founder, BendWorks AI',
  },
  {
    quote: 'Finally, a wellness benefit that says “we value you” and “please ignore the flaming pine bucket near Legal.”',
    name: 'Anita Bath',
    title: 'Chief People Person, HotDesk.io',
  },
];

const faqs = [
  {
    question: 'Will the truck fit in our corporate parking garage?',
    answer: 'Probably not, which is why every subscription includes a tasteful lobby honk and a very persuasive valet strategy.',
  },
  {
    question: 'Is birch whipping mandatory?',
    answer: 'No. Employees may choose Gentle Sprig, Performance Thwack, or Executive Rustle depending on comfort with foliage-based coaching.',
  },
  {
    question: 'Can we expense this as software?',
    answer: 'Absolutely. SaaS stands for Sauna-as-a-Service, and our invoices use enough cloud words to make Finance feel warm inside.',
  },
];

const steps = [
  {
    title: 'Schedule the ambush.',
    copy: 'Pick a meeting with enough buzzwords to justify steam intervention.',
  },
  {
    title: 'Truck arrives silently.',
    copy: 'Electric drivetrain. Monster tires. Mild panic in Facilities.',
  },
  {
    title: 'Heat unlocks insight.',
    copy: 'Employees return flushed, focused, and legally unable to say “circle back.”',
  },
];

const brands = ['Sweatforce', 'HotDesk.io', 'SaunaCloud', 'BirchOps'];
---

<Layout title="Sauna-as-a-Service | Mobile Corporate Sauna Trucks">
  <main class="page">
    <Navigation />
    <Hero />
    <LogoStrip brands={brands} />
    <FeaturesSection features={features} />
    <ImageShowcase />
    <HowItWorksSection steps={steps} />
    <PricingSection plans={plans} />
    <TestimonialsSection testimonials={testimonials} />
    <FAQSection faqs={faqs} />
    <FinalCTA />
    <SiteFooter />
  </main>
</Layout>
