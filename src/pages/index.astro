---
import Layout from '../layouts/Layout.astro';

const features = [
  ['🚚', 'Meeting-room extraction', 'Our silent electric monster truck arrives during your Q3 sync. You leave for a “quick alignment” and return glowing like a volcano with an MBA.'],
  ['🌿', 'Birch branch enablement', 'Certified Wellness Whackers provide artisanal löyly and foliage-based coaching until your roadmap sweats.'],
  ['🏆', 'Victory & tar aroma', 'Walk back into the boardroom smelling like cedar, decisive leadership, and one suspiciously premium campfire.'],
  ['📈', 'Heat-level analytics', 'Track sweat velocity, action-item evaporation, and how often Sales says “disruptive” inside a 190° sauna.'],
];

const plans = [
  {
    name: 'Warm Intro', price: '$899', period: '/ ambush', featured: false,
    copy: 'For startups that say “family” but mean “bring your own towel.”',
    items: ['One sauna truck visit', 'Two birch morale boosts', 'Slack status: In deep focus', 'Tar-scented badge sticker'],
  },
  {
    name: 'Synergy Steam', price: '$4,200', period: '/ month', featured: true,
    copy: 'The executive favorite. Enough heat to melt silos and weak OKRs.',
    items: ['Weekly monster truck deployments', 'Productivity heat levels 1–7', 'Quarterly sweat retrospective', 'Priority parking-lot intimidation'],
  },
  {
    name: 'Boardroom Inferno', price: 'Custom', period: '', featured: false,
    copy: 'For enterprises ready to boil bureaucracy until it becomes soup.',
    items: ['Dedicated Chief Sweat Officer', 'Unlimited birch ceremonies', 'SEC-compliant towel storage', 'White-glove all-hands evacuation'],
  },
];

const testimonials = [
  ['I stepped out during a budget meeting and came back with pores so open I approved the roadmap by smell alone.', 'Dick Swett', 'CEO, MoistMetrics Global'],
  ['Our velocity doubled after Sauna-as-a-Service. Mostly because everyone sprinted back inside when the truck did a wheelie.', 'Ben Dover', 'Founder, BendWorks AI'],
  ['Finally, a wellness benefit that says “we value you” and “please ignore the flaming pine bucket near Legal.”', 'Anita Bath', 'Chief People Person, HotDesk.io'],
];

const faqs = [
  ['Will the truck fit in our corporate parking garage?', 'Probably not, which is why every subscription includes a tasteful lobby honk and a very persuasive valet strategy.'],
  ['Is birch whipping mandatory?', 'No. Employees may choose Gentle Sprig, Performance Thwack, or Executive Rustle depending on comfort with foliage-based coaching.'],
  ['Can we expense this as software?', 'Absolutely. SaaS stands for Sauna-as-a-Service, and our invoices use enough cloud words to make Finance feel warm inside.'],
];
---

<Layout title="Sauna-as-a-Service | Mobile Corporate Sauna Trucks">
  <main class="page">
    <nav class="nav" aria-label="Primary navigation">
      <a class="brand" href="#top" aria-label="Sauna-as-a-Service home"><span>S</span> Sauna-as-a-Service</a>
      <div class="nav-links"><a href="#features">Features</a><a href="#pricing">Pricing</a><a href="#faq">FAQ</a></div>
      <a class="nav-cta" href="#pricing">Book the truck</a>
    </nav>

    <section id="top" class="hero" aria-labelledby="hero-title">
      <div class="hero-copy">
        <p class="eyebrow">Corporate wellness, but with torque</p>
        <h1 id="hero-title">The luxury sauna truck that crashes your meeting on purpose.</h1>
        <p class="hero-intro">Sauna-as-a-Service is the world’s first premium fleet of mobile saunas mounted on electric monster trucks. Step out for a “wellness break,” get whipped with birch branches, and return smelling like victory, tar, and promotion potential.</p>
        <div class="hero-actions"><a class="button primary" href="#pricing">Start sweating strategically</a><a class="button secondary" href="#demo">Watch the fake demo</a></div>
        <dl class="metrics" aria-label="Company metrics">
          <div><dt>99.9%</dt><dd>Meeting escape uptime</dd></div>
          <div><dt>7</dt><dd>Productivity heat levels</dd></div>
          <div><dt>0g</dt><dd>Tailpipe emissions, maximum vibes</dd></div>
        </dl>
      </div>
      <div class="truck-card" aria-label="Illustration of an electric monster truck sauna">
        <div class="steam s1"></div><div class="steam s2"></div><div class="steam s3"></div>
        <div class="sauna-box"><span class="chimney"></span><span class="window"></span><span class="door"></span><strong>SaaS</strong></div>
        <div class="truck-bed"></div><div class="wheel left"></div><div class="wheel right"></div><div class="zap">⚡</div>
      </div>
    </section>

    <section class="logo-strip" aria-label="Imaginary customers"><span>Trusted by teams at</span><strong>Sweatforce</strong><strong>HotDesk.io</strong><strong>SaunaCloud</strong><strong>BirchOps</strong></section>

    <section id="features" class="section" aria-labelledby="features-title">
      <p class="eyebrow">Features</p>
      <h2 id="features-title">Everything your office needs to perspire with purpose.</h2>
      <div class="feature-grid">
        {features.map(([icon, title, copy]) => <article class="feature-card"><span aria-hidden="true">{icon}</span><h3>{title}</h3><p>{copy}</p></article>)}
      </div>
    </section>

    <section id="demo" class="split section" aria-labelledby="demo-title">
      <div><p class="eyebrow">How it works</p><h2 id="demo-title">From calendar invite to cedar-scented dominance in 12 minutes.</h2></div>
      <ol class="steps">
        <li><strong>Schedule the ambush.</strong><span>Pick a meeting with enough buzzwords to justify steam intervention.</span></li>
        <li><strong>Truck arrives silently.</strong><span>Electric drivetrain. Monster tires. Mild panic in Facilities.</span></li>
        <li><strong>Heat unlocks insight.</strong><span>Employees return flushed, focused, and legally unable to say “circle back.”</span></li>
      </ol>
    </section>

    <section id="pricing" class="section pricing" aria-labelledby="pricing-title">
      <p class="eyebrow">Subscriptions</p>
      <h2 id="pricing-title">Productivity heat levels for every burn rate.</h2>
      <div class="pricing-grid">
        {plans.map((plan) => <article class:list={['plan', { featured: plan.featured }]}><p class="plan-kicker">{plan.featured ? 'Most unnecessarily popular' : 'Corporate-approved'}</p><h3>{plan.name}</h3><p class="price">{plan.price}<span>{plan.period}</span></p><p>{plan.copy}</p><ul>{plan.items.map((item) => <li>{item}</li>)}</ul><a class="button" href="#faq">Choose {plan.name}</a></article>)}
      </div>
    </section>

    <section class="section testimonials" aria-labelledby="testimonials-title">
      <p class="eyebrow">Testimonials</p>
      <h2 id="testimonials-title">Loved by leaders with extremely damp confidence.</h2>
      <div class="testimonial-grid">
        {testimonials.map(([quote, name, title]) => <figure><blockquote>“{quote}”</blockquote><figcaption><strong>{name}</strong><span>{title}</span></figcaption></figure>)}
      </div>
    </section>

    <section id="faq" class="section faq" aria-labelledby="faq-title">
      <div><p class="eyebrow">FAQ</p><h2 id="faq-title">Questions your CFO is already sweating.</h2></div>
      <div class="faq-list">{faqs.map(([question, answer]) => <article><h3>{question}</h3><p>{answer}</p></article>)}</div>
    </section>

    <section class="final-cta" aria-labelledby="cta-title">
      <p class="eyebrow">Ready for thermal transformation?</p>
      <h2 id="cta-title">Turn your next status meeting into a luxury sweat incident.</h2>
      <a class="button primary" href="mailto:sweat@sauna-as-a-service.example">Request a very serious demo</a>
    </section>

    <footer><span>© 2026 Sauna-as-a-Service</span><span>No actual executives were steamed in the making of this landing page.</span></footer>
  </main>
</Layout>

<style>
  :global(*) { box-sizing: border-box; }
  :global(html) { scroll-behavior: smooth; background: #120b08; }
  :global(body) { font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; color: #fff7ed; background: #120b08; }
  :global(a) { color: inherit; }

  .page { min-height: 100vh; overflow: hidden; background: radial-gradient(circle at 15% 5%, rgba(251, 146, 60, .32), transparent 28rem), radial-gradient(circle at 88% 9%, rgba(244, 63, 94, .22), transparent 24rem), linear-gradient(135deg, #140c08 0%, #2b160d 48%, #0f172a 100%); }
  .page::before { content: ''; position: fixed; inset: 0; pointer-events: none; opacity: .12; background-image: linear-gradient(rgba(255,255,255,.08) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,.08) 1px, transparent 1px); background-size: 42px 42px; mask-image: linear-gradient(to bottom, #000, transparent); }
  .nav, .hero, .section, .logo-strip, .final-cta, footer { width: min(1160px, calc(100% - 32px)); margin-inline: auto; }
  .nav { position: sticky; top: 16px; z-index: 5; display: flex; align-items: center; justify-content: space-between; gap: 1rem; padding: .75rem; margin-top: 16px; border: 1px solid rgba(255,237,213,.16); border-radius: 999px; background: rgba(18, 11, 8, .72); backdrop-filter: blur(18px); box-shadow: 0 18px 60px rgba(0,0,0,.24); }
  .brand, .nav-links, .nav-cta, .button { text-decoration: none; font-weight: 800; }
  .brand { display: inline-flex; align-items: center; gap: .65rem; letter-spacing: -.03em; }
  .brand span { display: grid; place-items: center; width: 2.25rem; height: 2.25rem; border-radius: 50%; color: #1b0f0a; background: linear-gradient(135deg, #fdba74, #fb7185); box-shadow: 0 0 34px rgba(251,146,60,.42); }
  .nav-links { display: flex; gap: .35rem; color: #fed7aa; font-size: .92rem; }
  .nav-links a { padding: .7rem .9rem; border-radius: 999px; text-decoration: none; }
  .nav-links a:hover, .nav-links a:focus-visible { background: rgba(255,237,213,.1); outline: none; }
  .nav-cta, .button { display: inline-flex; align-items: center; justify-content: center; border-radius: 999px; transition: transform .2s ease, box-shadow .2s ease, background .2s ease; }
  .nav-cta { padding: .8rem 1rem; color: #1f120b; background: #fed7aa; }
  .button { min-height: 3.1rem; padding: .85rem 1.15rem; border: 1px solid rgba(255,237,213,.22); background: rgba(255,237,213,.08); }
  .button:hover, .button:focus-visible, .nav-cta:hover, .nav-cta:focus-visible { transform: translateY(-2px); outline: none; box-shadow: 0 14px 34px rgba(251,146,60,.18); }
  .primary { color: #1c100a; border: 0; background: linear-gradient(135deg, #fed7aa, #fb7185); }
  .secondary { color: #ffedd5; }

  .hero { display: grid; grid-template-columns: minmax(0, 1.03fr) minmax(320px, .97fr); gap: clamp(2rem, 5vw, 5rem); align-items: center; padding: clamp(5rem, 10vw, 8rem) 0 4rem; }
  .eyebrow { margin: 0 0 .85rem; color: #fdba74; font-size: .78rem; font-weight: 900; letter-spacing: .18em; text-transform: uppercase; }
  h1, h2, h3, p { margin-top: 0; }
  h1 { margin-bottom: 1.35rem; max-width: 11ch; font-size: clamp(3.5rem, 8vw, 7.7rem); line-height: .84; letter-spacing: -.085em; text-wrap: balance; }
  h2 { margin-bottom: 1rem; max-width: 760px; font-size: clamp(2.25rem, 5vw, 4.6rem); line-height: .92; letter-spacing: -.065em; text-wrap: balance; }
  h3 { margin-bottom: .6rem; font-size: 1.2rem; letter-spacing: -.035em; }
  .hero-intro, .section > p:not(.eyebrow), .feature-card p, .plan p, .faq p, .steps span, figure span { color: #fed7aa; line-height: 1.7; }
  .hero-intro { max-width: 63ch; font-size: clamp(1.1rem, 2vw, 1.35rem); }
  .hero-actions { display: flex; flex-wrap: wrap; gap: .85rem; margin: 2rem 0; }
  .metrics { display: grid; grid-template-columns: repeat(3, 1fr); gap: .75rem; margin: 0; }
  .metrics div { padding: 1rem; border: 1px solid rgba(255,237,213,.14); border-radius: 22px; background: rgba(255,255,255,.055); }
  .metrics dt { font-size: 1.45rem; font-weight: 900; color: #fff7ed; }
  .metrics dd { margin: .25rem 0 0; color: #fdba74; font-size: .86rem; }

  .truck-card { position: relative; min-height: 500px; border: 1px solid rgba(255,237,213,.16); border-radius: 42px; background: linear-gradient(160deg, rgba(255,255,255,.13), rgba(255,255,255,.04)), radial-gradient(circle at 50% 20%, rgba(251,146,60,.28), transparent 18rem); box-shadow: inset 0 1px 0 rgba(255,255,255,.14), 0 35px 90px rgba(0,0,0,.33); overflow: hidden; }
  .truck-card::after { content: 'PRODUCTIVITY HEAT LEVEL 7'; position: absolute; right: -4.2rem; bottom: 5.2rem; transform: rotate(-90deg); color: rgba(255,237,213,.32); font-weight: 900; letter-spacing: .18em; font-size: .78rem; }
  .sauna-box { position: absolute; left: 12%; right: 12%; bottom: 170px; height: 180px; border-radius: 28px 28px 18px 18px; padding: 1.4rem; color: #2a1308; background: repeating-linear-gradient(90deg, #b7652e 0 24px, #d98a45 24px 48px); box-shadow: inset 0 0 0 5px rgba(255,237,213,.18), 0 24px 50px rgba(0,0,0,.34); }
  .sauna-box strong { position: absolute; left: 1.3rem; bottom: 1rem; font-size: 3rem; letter-spacing: -.08em; color: rgba(43,22,13,.75); }
  .chimney { position: absolute; top: -68px; right: 55px; width: 38px; height: 80px; border-radius: 12px 12px 0 0; background: #2d1b12; }
  .window, .door { position: absolute; top: 48px; border-radius: 16px; background: linear-gradient(135deg, #ffedd5, #fb7185); box-shadow: 0 0 30px rgba(251,113,133,.55); }
  .window { left: 42px; width: 82px; height: 62px; }
  .door { right: 44px; width: 78px; height: 112px; }
  .truck-bed { position: absolute; left: 8%; right: 8%; bottom: 120px; height: 55px; border-radius: 999px; background: linear-gradient(90deg, #111827, #334155, #111827); }
  .wheel { position: absolute; bottom: 58px; width: 118px; height: 118px; border: 18px solid #0b0f19; border-radius: 50%; background: radial-gradient(circle, #fdba74 0 18%, #334155 19% 34%, #111827 35%); box-shadow: 0 18px 30px rgba(0,0,0,.4); }
  .wheel.left { left: 13%; } .wheel.right { right: 13%; }
  .zap { position: absolute; left: 50%; bottom: 72px; transform: translateX(-50%); display: grid; place-items: center; width: 64px; height: 64px; border-radius: 50%; background: #fdba74; color: #1c100a; font-size: 2rem; box-shadow: 0 0 42px rgba(253,186,116,.72); }
  .steam { position: absolute; bottom: 340px; width: 42px; height: 150px; border-radius: 999px; background: rgba(255,247,237,.18); filter: blur(8px); }
  .s1 { left: 26%; transform: rotate(16deg); } .s2 { left: 48%; bottom: 360px; height: 190px; } .s3 { right: 24%; transform: rotate(-15deg); }

  .logo-strip { display: flex; align-items: center; justify-content: center; flex-wrap: wrap; gap: 1rem 2rem; padding: 1rem; margin-bottom: 4rem; border-block: 1px solid rgba(255,237,213,.12); color: #fed7aa; }
  .logo-strip strong { color: #fff7ed; letter-spacing: -.03em; }
  .section { padding: 5rem 0; }
  .feature-grid, .pricing-grid, .testimonial-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; }
  .feature-grid { grid-template-columns: repeat(4, 1fr); margin-top: 2rem; }
  .feature-card, .plan, figure, .faq article, .steps li, .final-cta { border: 1px solid rgba(255,237,213,.14); background: rgba(255,255,255,.06); box-shadow: inset 0 1px 0 rgba(255,255,255,.09); }
  .feature-card { padding: 1.35rem; border-radius: 28px; }
  .feature-card > span { display: inline-grid; place-items: center; width: 3rem; height: 3rem; margin-bottom: 1rem; border-radius: 18px; background: rgba(253,186,116,.14); font-size: 1.45rem; }
  .split, .faq { display: grid; grid-template-columns: .85fr 1.15fr; gap: 2rem; align-items: start; }
  .steps { display: grid; gap: .9rem; padding: 0; margin: 0; list-style: none; counter-reset: step; }
  .steps li { position: relative; padding: 1.3rem 1.3rem 1.3rem 4.2rem; border-radius: 26px; counter-increment: step; }
  .steps li::before { content: counter(step); position: absolute; left: 1.1rem; top: 1.1rem; display: grid; place-items: center; width: 2rem; height: 2rem; border-radius: 50%; color: #1c100a; font-weight: 900; background: #fdba74; }
  .steps strong, .steps span { display: block; }
  .pricing-grid { align-items: stretch; margin-top: 2rem; }
  .plan { display: flex; flex-direction: column; padding: 1.4rem; border-radius: 32px; }
  .plan.featured { background: linear-gradient(180deg, rgba(251,146,60,.22), rgba(255,255,255,.07)); border-color: rgba(253,186,116,.45); transform: translateY(-12px); }
  .plan-kicker { color: #fdba74; font-size: .75rem; font-weight: 900; letter-spacing: .12em; text-transform: uppercase; }
  .price { margin: .75rem 0; color: #fff7ed; font-size: 2.7rem; font-weight: 950; letter-spacing: -.06em; }
  .price span { color: #fed7aa; font-size: 1rem; font-weight: 700; letter-spacing: 0; }
  .plan ul { display: grid; gap: .65rem; padding: 0; margin: 1rem 0 1.3rem; list-style: none; color: #ffedd5; }
  .plan li::before { content: '✓'; margin-right: .6rem; color: #fdba74; font-weight: 900; }
  .plan .button { margin-top: auto; }
  figure { margin: 0; padding: 1.4rem; border-radius: 30px; }
  blockquote { margin: 0 0 1.2rem; color: #fff7ed; font-size: 1.1rem; line-height: 1.65; }
  figcaption { display: grid; gap: .15rem; }
  .faq-list { display: grid; gap: .9rem; }
  .faq article { padding: 1.3rem; border-radius: 26px; }
  .final-cta { margin-top: 4rem; padding: clamp(2rem, 6vw, 5rem); border-radius: 42px; text-align: center; background: radial-gradient(circle at 50% 0%, rgba(251,113,133,.28), transparent 24rem), rgba(255,255,255,.07); }
  .final-cta h2 { margin-inline: auto; }
  footer { display: flex; justify-content: space-between; gap: 1rem; padding: 2rem 0 3rem; color: #fed7aa; font-size: .9rem; }

  @media (max-width: 900px) {
    .nav-links { display: none; }
    .hero, .split, .faq { grid-template-columns: 1fr; }
    .truck-card { min-height: 420px; }
    .feature-grid, .pricing-grid, .testimonial-grid { grid-template-columns: 1fr 1fr; }
    .plan.featured { transform: none; }
  }
  @media (max-width: 640px) {
    .nav { border-radius: 24px; }
    .brand { font-size: .92rem; }
    .nav-cta { display: none; }
    h1 { max-width: 100%; }
    .metrics, .feature-grid, .pricing-grid, .testimonial-grid { grid-template-columns: 1fr; }
    .hero { padding-top: 3.5rem; }
    .truck-card { min-height: 360px; border-radius: 30px; }
    .sauna-box { left: 8%; right: 8%; bottom: 150px; height: 150px; }
    .wheel { width: 92px; height: 92px; border-width: 14px; }
    footer { flex-direction: column; }
  }
</style>
